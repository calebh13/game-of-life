{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug MPI",
            "type": "cppdbg",
            "request": "launch",
            "program": "/usr/bin/mpirun",
            "args": ["-np", "4", "--use-hwthread-cpus", "--mca", "btl_vader_single_copy_mechanism", "none", "./main"],
